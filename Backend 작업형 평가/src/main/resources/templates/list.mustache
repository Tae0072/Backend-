<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>방명록</title>
    <style>
        body { font-family: sans-serif; max-width: 700px; margin: 40px auto; padding: 0 20px; }
        .entry { border: 1px solid #ddd; border-radius: 8px; padding: 16px; margin-bottom: 16px; }
        .entry .meta { font-size: 0.85em; color: #888; margin-bottom: 8px; }
        .entry .content { margin-bottom: 12px; }
        .btn { padding: 6px 14px; border: none; border-radius: 4px; cursor: pointer; }
        .btn-write { background: #4CAF50; color: white; text-decoration: none; padding: 8px 16px; border-radius: 4px; }
        .btn-delete { background: #f44336; color: white; }
        h1 { border-bottom: 2px solid #333; padding-bottom: 10px; }
        .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .empty { color: #999; text-align: center; padding: 40px; }
    </style>
</head>
<body>

<h1>📖 방명록</h1>

<div class="top">
    <span>총 {{list.size}}개의 글</span>
    <a href="/guestbook/write" class="btn-write">✏️ 글쓰기</a>
</div>

{{#list}}
<div class="entry">
    <div class="meta">
        <strong>{{author}}</strong> · {{createdAt}}
    </div>
    <div class="content">{{content}}</div>
    <form action="/guestbook/{{id}}/delete" method="post">
        <button type="submit" class="btn btn-delete"
                onclick="return confirm('삭제하시겠습니까?')">삭제</button>
    </form>
</div>
{{/list}}

{{^list}}
<div class="empty">아직 작성된 글이 없습니다.</div>
{{/list}}

</body>
</html>
